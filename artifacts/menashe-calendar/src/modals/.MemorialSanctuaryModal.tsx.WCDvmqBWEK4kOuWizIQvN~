        </div>
        <div style={{ fontSize: 10, color: "rgba(35,18,0,0.4)", fontVariantNumeric: "tabular-nums", letterSpacing: "0.06em" }}>
          {progress}%
        </div>
      </div>
    </div>
  );
}

